# RecallLens environment configuration
# Copy to .env and adjust. NEVER commit real secrets.

# ─── Midnight network (local devnet by default) ──────────────────────────────
# undeployed = local Docker devnet (node/indexer/proof-server)
MIDNIGHT_NETWORK=undeployed
MIDNIGHT_INDEXER_URL=http://127.0.0.1:8088/api/v4/graphql
MIDNIGHT_INDEXER_WS_URL=ws://127.0.0.1:8088/api/v4/graphql/ws
MIDNIGHT_NODE_URL=ws://127.0.0.1:9944
MIDNIGHT_PROOF_SERVER_URL=http://127.0.0.1:6300

# The genesis-funded seed is used ONLY on the local devnet. For public networks,
# provide your own funded seed here (do not commit it).
# MIDNIGHT_WALLET_SEED=

# Private-state store password (>=16 chars). Local-devnet placeholder only.
PRIVATE_STATE_PASSWORD=Local-Devnet-Development-Placeholder-1

# Deployed RecallLens contract address (written by the deploy script).
# RECALLLENS_CONTRACT_ADDRESS=

# ─── public-data-api ─────────────────────────────────────────────────────────
PORT=8787

# ─── web app ─────────────────────────────────────────────────────────────────
# Where the web app reaches the API. Defaults to the Vite proxy (/api).
# VITE_API_BASE=/api
